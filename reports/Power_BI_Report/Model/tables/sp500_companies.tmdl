	column added_to_sp500
		dataType: dateTime
		formatString: Long Date
		summarizeBy: none
		sourceColumn: added_to_sp500

		variation Variation
			isDefault
			relationship: 8afb5141-d5cd-48f9-a514-82163db9f283
			defaultHierarchy: LocalDateTable_3cbfe9ca-8621-402e-9116-c64acb825834.'Date Hierarchy'

